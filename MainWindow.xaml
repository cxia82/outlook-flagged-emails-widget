<Window x:Class="NotificationWidget.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:NotificationWidget"
        Title="🚩 Flagged Emails"
        Icon="app.ico"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="#DD242424"
        Topmost="False"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip"
        MinWidth="280" MinHeight="180"
        Width="380" Height="300"
        Loaded="Window_Loaded">
    <Border Padding="14">
        <DockPanel>
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" VerticalAlignment="Center"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" Cursor="SizeAll">
                <Ellipse Width="12" Height="12" Fill="#FF4CAF50" VerticalAlignment="Center"/>
                <TextBlock x:Name="TitleText" Text="Flagged Emails" Margin="10,0,0,0" FontWeight="Bold" Foreground="White" FontSize="16" HorizontalAlignment="Left"/>
                <Button x:Name="CloseButton" Click="CloseButton_Click" Margin="8,0,0,0" Background="Transparent" BorderThickness="0" Foreground="#FFDDDDDD" FontSize="18" Padding="8,0">&#x2715;</Button>
            </StackPanel>
            <TextBlock x:Name="StatusText" DockPanel.Dock="Bottom" Margin="0,8,0,0" Foreground="#FFAAAAAA" FontSize="11"/>
            <ListBox x:Name="FlaggedItemsList" Margin="0,12,0,0" Foreground="#FFDDDDDD" Background="Transparent" BorderThickness="0"
                     HorizontalContentAlignment="Stretch" ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled" MouseDoubleClick="FlaggedItemsList_DoubleClick">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,4,0,4">
                            <local:TwoLineEllipsisTextBlock Text="{Binding Subject}" FontWeight="SemiBold" Foreground="White" FontSize="13"/>
                            <TextBlock Text="{Binding Sender}" Foreground="#FFAAAAAA" FontSize="11" Margin="0,2,0,0"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>
    </Border>
</Window>
